# storypipe 환경변수 (모두 선택). 셸에서 export 하거나 복사해 .env로 사용.

# EXAONE GGUF GPU offload 레이어 수 (기본 0 = CPU, 어디서나 동작). NVIDIA GPU 가속 시 999.
LLAMA_GPU_LAYERS=0

# EXAONE GGUF 컨텍스트 길이 (기본 8192).
# EXAONE_N_CTX=8192

# 이미 받아둔 EXAONE GGUF 파일을 직접 지정(자동 다운로드 대신).
# EXAONE_GGUF_MODEL_PATH=/path/to/EXAONE-4.0-1.2B-IQ4_XS.gguf

# Hugging Face 로그인이 필요한(게이트) 모델 다운로드용 토큰.
# HF_TOKEN=hf_xxxxxxxx

# 모델 리비전 고정(재현성). 키는 HF_REVISION_<모델ID에서 / . - 를 _ 로 치환>.
# 예) Qwen/Qwen2.5-VL-3B-Instruct →
# HF_REVISION_Qwen_Qwen2_5_VL_3B_Instruct=<revision-hash>
